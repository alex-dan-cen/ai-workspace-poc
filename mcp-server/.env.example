# ─────────────────────────────────────────────────────────────
#  Copy to `.env` and `source .env` BEFORE launching the editor.
#  The MCP server reads these from process.env at runtime.
#  Do NOT commit the real .env file.
# ─────────────────────────────────────────────────────────────

# === GitHub ===
# Create at: https://github.com/settings/tokens?type=beta
# Scopes: repo (read+write), pull_requests (read+write)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Jira + Confluence (shared Atlassian token) ===
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_SITE_NAME=yourcompany           # the "yourcompany" in yourcompany.atlassian.net
ATLASSIAN_USER_EMAIL=you@yourcompany.com
ATLASSIAN_API_TOKEN=ATATTxxxxxxxxxxxxxxxx

# === SonarQube ===
# Create at: <sonar>/account/security
SONARQUBE_URL=https://sonar.yourcompany.com
SONARQUBE_TOKEN=squ_xxxxxxxxxxxxxxxxxxxx
SONARQUBE_PROJECT_KEY=yourcompany:yourproject

# === Chrome DevTools MCP ===
# No token required. Make sure Chrome is installed locally.